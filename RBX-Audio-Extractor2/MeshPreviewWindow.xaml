<Window x:Class="MeshPreviewWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Mesh Preview" Width="900" Height="650" MinWidth="560" MinHeight="420" Background="{StaticResource CanvasBrush}" Foreground="{StaticResource TextBrush}" WindowStartupLocation="CenterOwner">
    <Grid><Grid.RowDefinitions><RowDefinition Height="66"/><RowDefinition Height="*"/><RowDefinition Height="34"/></Grid.RowDefinitions>
        <Border Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"><Grid Margin="18,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel VerticalAlignment="Center"><TextBlock x:Name="TitleText" FontSize="16" FontWeight="SemiBold"/><TextBlock x:Name="DetailsText" Style="{StaticResource MutedText}" Margin="0,4,0,0"/></StackPanel><Button Grid.Column="1" Content="Reset view" Style="{StaticResource SecondaryButton}" Click="ResetButton_Click"/></Grid></Border>
        <Border Grid.Row="1" Margin="14" CornerRadius="12" Background="#0C0D12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" ClipToBounds="True"><Viewport3D x:Name="Viewport" MouseLeftButtonDown="Viewport_MouseLeftButtonDown" MouseLeftButtonUp="Viewport_MouseLeftButtonUp" MouseMove="Viewport_MouseMove" MouseWheel="Viewport_MouseWheel"><Viewport3D.Camera><PerspectiveCamera x:Name="Camera" Position="0,0,4" LookDirection="0,0,-4" UpDirection="0,1,0" FieldOfView="45"/></Viewport3D.Camera></Viewport3D></Border>
        <Border Grid.Row="2" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"><TextBlock Text="Drag to rotate  •  Mouse wheel to zoom  •  Double-click to reset" Style="{StaticResource MutedText}" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
    </Grid>
</Window>