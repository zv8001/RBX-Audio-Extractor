<Window x:Class="AssetRenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename asset" Width="500" SizeToContent="Height" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent" ResizeMode="NoResize"
        ShowInTaskbar="False" WindowStartupLocation="CenterOwner">
    <Border Margin="18" CornerRadius="14" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Border.Effect><DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.45" Color="#000000"/></Border.Effect>
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="54"/><RowDefinition Height="Auto"/><RowDefinition Height="68"/></Grid.RowDefinitions>
            <Border Background="{StaticResource SidebarBrush}" CornerRadius="14,14,0,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid Margin="16,0"><TextBlock Text="Name cached asset" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/></Grid>
            </Border>
            <StackPanel Grid.Row="1" Margin="22,22,22,20">
                <TextBlock Text="Give this asset a recognizable name" Style="{StaticResource SectionTitle}" Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="The name is stored locally against a SHA-256 fingerprint and will be restored during future scans." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,6,0,16"/>
                <Border Height="38" Style="{StaticResource RoundedTextBoxShell}"><TextBox x:Name="NameBox" Style="{StaticResource SingleLineTextBox}" MaxLength="120"/></Border>
                <TextBlock Text="Leave it empty or choose Remove saved name to return to the cache key." Style="{StaticResource MutedText}" Margin="0,9,0,0"/>
            </StackPanel>
            <Border Grid.Row="2" Background="#181A22" CornerRadius="0,0,14,14" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid Margin="16,0"><StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center"><Button Content="Remove saved name" Style="{StaticResource DangerButton}" Click="RemoveButton_Click"/></StackPanel><StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"><Button Content="Cancel" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="CancelButton_Click"/><Button Content="Save name" Style="{StaticResource PrimaryButton}" IsDefault="True" Click="SaveButton_Click"/></StackPanel></Grid>
            </Border>
        </Grid>
    </Border>
</Window>