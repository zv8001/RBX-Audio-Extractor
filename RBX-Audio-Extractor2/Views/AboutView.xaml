<UserControl x:Class="Views.AboutView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="0.8*"/><ColumnDefinition Width="1.2*"/></Grid.ColumnDefinitions>
        <StackPanel Margin="0,0,9,0">
            <Border Style="{StaticResource Card}" Margin="0,0,0,16"><StackPanel><Border Width="54" Height="54" CornerRadius="15" Background="{StaticResource AccentBrush}" HorizontalAlignment="Left"><TextBlock Text="R" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Text="RBX Asset Extractor" FontSize="21" FontWeight="SemiBold" Margin="0,15,0,2"/><TextBlock x:Name="VersionText" Style="{StaticResource MutedText}"/><TextBlock Text="Made by zv800 / Vex" Foreground="{StaticResource AccentBrightBrush}" Margin="0,13,0,0"/><WrapPanel Margin="0,16,0,0"><Button Content="Check for updates" Style="{StaticResource PrimaryButton}" Margin="0,0,8,8" Click="CheckUpdatesButton_Click"/><Button x:Name="DownloadUpdateButton" Content="Download update" Style="{StaticResource PrimaryButton}" Margin="0,0,8,8" Visibility="Collapsed" Click="DownloadUpdateButton_Click"/><Button Content="Official website" Style="{StaticResource PrimaryButton}" Margin="0,0,8,8" Click="OpenProjectWebsiteButton_Click"/><Button Content="GitHub" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8" Click="OpenGithubButton_Click"/><Button Content="Creator website" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8" Click="OpenWebsiteButton_Click"/></WrapPanel></StackPanel></Border>
            <Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="Creator message" Style="{StaticResource SectionTitle}"/><TextBlock x:Name="CreatorMessageText" Text="No message loaded." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,8,0,0"/><Button Content="Refresh message" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Margin="0,14,0,0" Click="RefreshMessageButton_Click"/></StackPanel></Border>
        </StackPanel>
        <Border Grid.Column="1" Style="{StaticResource Card}" Margin="9,0,0,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock Text="Activity log" Style="{StaticResource SectionTitle}"/><ListBox x:Name="ActivityList" Grid.Row="1" Margin="0,14,0,12" Background="{StaticResource RaisedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" FontFamily="Cascadia Mono, Consolas" FontSize="12" ItemsSource="{Binding}"/><Button Grid.Row="2" Content="Clear log" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" Click="ClearLogButton_Click"/></Grid></Border>
    </Grid>
</UserControl>