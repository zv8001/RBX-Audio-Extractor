<UserControl x:Class="Views.AboutView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
        <StackPanel>
            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="58"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Width="54" Height="54" CornerRadius="15" Background="{StaticResource AccentBrush}" HorizontalAlignment="Left" VerticalAlignment="Top"><TextBlock Text="R" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    <StackPanel Grid.Column="1" Margin="14,0,0,0"><TextBlock Text="RBX Asset Extractor" FontSize="22" FontWeight="SemiBold"/><TextBlock Text="Local Roblox cache inspection and export." Style="{StaticResource MutedText}" Margin="0,5,0,0"/><TextBlock Text="Made by zv800 / Vex" Foreground="{StaticResource AccentBrightBrush}" Margin="0,8,0,0"/><WrapPanel Margin="0,18,0,0"><Button Content="Official website" Style="{StaticResource PrimaryButton}" Margin="0,0,8,8" Click="OpenProjectWebsiteButton_Click"/><Button Content="GitHub" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8" Click="OpenGithubButton_Click"/><Button Content="Creator website" Style="{StaticResource SecondaryButton}" Margin="0,0,0,8" Click="OpenWebsiteButton_Click"/></WrapPanel></StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Updates" Style="{StaticResource SectionTitle}"/>
                    <Grid Margin="0,13,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="0.75*"/><ColumnDefinition Width="0.9*"/><ColumnDefinition Width="1.6*"/></Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Text="INSTALLED" Style="{StaticResource EyebrowText}"/><TextBlock x:Name="VersionText" FontSize="16" FontWeight="SemiBold" Margin="0,5,0,0"/></StackPanel>
                        <StackPanel Grid.Column="1"><TextBlock Text="PUBLISHED" Style="{StaticResource EyebrowText}"/><TextBlock x:Name="LatestVersionText" Text="Not checked" FontSize="16" FontWeight="SemiBold" Margin="0,5,0,0" TextTrimming="CharacterEllipsis"/></StackPanel>
                        <StackPanel Grid.Column="2"><TextBlock Text="STATUS" Style="{StaticResource EyebrowText}"/><TextBlock x:Name="UpdateStatusText" Text="Ready to check for updates." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,5,0,0"/></StackPanel>
                    </Grid>
                    <WrapPanel Margin="0,16,0,0"><Button x:Name="CheckUpdatesButton" Content="Check for updates" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="CheckUpdatesButton_Click"/><Button x:Name="DownloadUpdateButton" Content="Download update" Style="{StaticResource PrimaryButton}" Visibility="Collapsed" Click="DownloadUpdateButton_Click"/></WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                <StackPanel><TextBlock Text="Creator message" Style="{StaticResource SectionTitle}"/><TextBlock x:Name="CreatorMessageText" Text="No message loaded." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,9,0,0"/><Button Content="Refresh message" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Margin="0,15,0,0" Click="RefreshMessageButton_Click"/></StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,2" Height="330">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock Text="Activity log" Style="{StaticResource SectionTitle}"/>
                    <ListBox x:Name="ActivityList" Grid.Row="1" Margin="0,14,0,12" Background="{StaticResource RaisedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" FontFamily="Cascadia Mono, Consolas" FontSize="12" ItemsSource="{Binding}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="6,3"/></DataTemplate></ListBox.ItemTemplate>
                    </ListBox>
                    <Button Grid.Row="2" Content="Clear log" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" Click="ClearLogButton_Click"/>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>