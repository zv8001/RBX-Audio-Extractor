<UserControl x:Class="Views.AudioView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="110"/></Grid.RowDefinitions>
        <WrapPanel Margin="0,0,0,4">
            <Border Width="300" Height="38" HorizontalAlignment="Left" Margin="0,0,0,8" Style="{StaticResource RoundedTextBoxShell}"><TextBox x:Name="SearchBox" Style="{StaticResource SingleLineTextBox}" TextChanged="SearchBox_TextChanged" ToolTip="Filter by cache hash, saved name, or format"/></Border>
            <StackPanel Orientation="Horizontal" Margin="12,0,0,8"><Button x:Name="ScanButton" Content="Scan cache" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Click="ScanButton_Click"/><Button x:Name="RenameButton" Content="Rename" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" IsEnabled="False" Click="RenameButton_Click"/><Button x:Name="ExportButton" Content="Export selected" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" IsEnabled="False" Click="ExportButton_Click"/><Button x:Name="ExportAllButton" Content="Export all" Style="{StaticResource SecondaryButton}" IsEnabled="False" Click="ExportAllButton_Click"/></StackPanel>
        </WrapPanel>
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="8">
            <ListView x:Name="AssetList" SelectionChanged="AssetList_SelectionChanged" MouseDoubleClick="AssetList_MouseDoubleClick" SizeChanged="AssetList_SizeChanged">
                <ListView.View><GridView><GridViewColumn x:Name="NameColumn" Header="NAME" DisplayMemberBinding="{Binding FriendlyName}"/><GridViewColumn x:Name="CacheKeyColumn" Header="CACHE KEY" DisplayMemberBinding="{Binding Hash}"/><GridViewColumn x:Name="FormatColumn" Header="FORMAT" DisplayMemberBinding="{Binding TypeLabel}"/><GridViewColumn x:Name="DurationColumn" Header="DURATION" DisplayMemberBinding="{Binding DurationText}"/><GridViewColumn x:Name="BytesColumn" Header="BYTES" DisplayMemberBinding="{Binding Size}"/><GridViewColumn x:Name="InlineColumn" Header="INLINE" DisplayMemberBinding="{Binding IsInline}"/></GridView></ListView.View>
            </ListView>
        </Border>
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,12,0,0" Padding="16">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Button x:Name="PlayPauseButton" Content="Play" Style="{StaticResource PrimaryButton}" Width="76" Height="44" Click="PlayPauseButton_Click"/><Button Content="Stop" Style="{StaticResource SecondaryButton}" Width="70" Height="44" Margin="8,0,0,0" Click="StopButton_Click"/></StackPanel>
                <StackPanel Grid.Column="1" Margin="18,0"><TextBlock x:Name="NowPlayingText" Text="Select a track to preview" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/><Grid Margin="0,9,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="96"/></Grid.ColumnDefinitions><Slider x:Name="PositionSlider" Minimum="0" Maximum="1" PreviewMouseLeftButtonDown="PositionSlider_PreviewMouseLeftButtonDown" PreviewMouseMove="PositionSlider_PreviewMouseMove" PreviewMouseLeftButtonUp="PositionSlider_PreviewMouseLeftButtonUp"/><TextBlock x:Name="TimeText" Grid.Column="1" Text="00:00 / 00:00" Style="{StaticResource MutedText}" HorizontalAlignment="Right"/></Grid></StackPanel>
                <StackPanel Grid.Column="2"><TextBlock Text="VOLUME" Style="{StaticResource EyebrowText}"/><Slider x:Name="VolumeSlider" Minimum="0" Maximum="1" Value="0.85" Margin="0,8,0,0" PreviewMouseLeftButtonDown="VolumeSlider_PreviewMouseLeftButtonDown" PreviewMouseMove="VolumeSlider_PreviewMouseMove" PreviewMouseLeftButtonUp="VolumeSlider_PreviewMouseLeftButtonUp" ValueChanged="VolumeSlider_ValueChanged"/></StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>