<UserControl x:Class="Views.CacheFilesView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox" Width="280" HorizontalAlignment="Left" TextChanged="Filter_Changed"/>
            <ComboBox x:Name="TypeFilter" Grid.Column="1" Margin="0,0,10,0" SelectedIndex="0" SelectionChanged="Filter_Changed"><ComboBoxItem Content="All cache files"/><ComboBoxItem Content="RBXM only"/><ComboBoxItem Content="KTX only"/></ComboBox>
            <StackPanel Grid.Column="2" Orientation="Horizontal"><Button x:Name="ScanButton" Content="Scan cache" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Click="ScanButton_Click"/><Button x:Name="ExportButton" Content="Export selected" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" IsEnabled="False" Click="ExportButton_Click"/><Button x:Name="ExportAllButton" Content="Export all" Style="{StaticResource SecondaryButton}" IsEnabled="False" Click="ExportAllButton_Click"/></StackPanel>
        </Grid>
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="8"><ListView x:Name="AssetList" SelectionChanged="AssetList_SelectionChanged"><ListView.View><GridView><GridViewColumn Header="CACHE KEY" Width="390" DisplayMemberBinding="{Binding Hash}"/><GridViewColumn Header="TYPE" Width="150" DisplayMemberBinding="{Binding TypeLabel}"/><GridViewColumn Header="BYTES" Width="140" DisplayMemberBinding="{Binding Size}"/><GridViewColumn Header="INLINE" Width="100" DisplayMemberBinding="{Binding IsInline}"/></GridView></ListView.View></ListView></Border>
    </Grid>
</UserControl>