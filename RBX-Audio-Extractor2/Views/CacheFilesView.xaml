<UserControl x:Class="Views.CacheFilesView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <WrapPanel Margin="0,0,0,4">
            <Border Width="260" Height="38" HorizontalAlignment="Left" Margin="0,0,12,8" Style="{StaticResource RoundedTextBoxShell}"><TextBox x:Name="SearchBox" Style="{StaticResource SingleLineTextBox}" TextChanged="Filter_Changed" ToolTip="Filter by cache key, saved name, or type"/></Border>
            <ComboBox x:Name="TypeFilter" Width="170" Height="38" Margin="0,0,12,8" VerticalContentAlignment="Center" SelectedIndex="0" SelectionChanged="Filter_Changed"><ComboBoxItem Content="All cache files"/><ComboBoxItem Content="RBXM only"/><ComboBoxItem Content="KTX only"/></ComboBox>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8"><Button x:Name="ScanButton" Content="Scan cache" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Click="ScanButton_Click"/><Button x:Name="RenameButton" Content="Rename" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" IsEnabled="False" Click="RenameButton_Click"/><Button x:Name="ExportButton" Content="Export selected" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" IsEnabled="False" Click="ExportButton_Click"/><Button x:Name="ExportAllButton" Content="Export all" Style="{StaticResource SecondaryButton}" IsEnabled="False" Click="ExportAllButton_Click"/></StackPanel>
        </WrapPanel>
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="8"><ListView x:Name="AssetList" SelectionChanged="AssetList_SelectionChanged" SizeChanged="AssetList_SizeChanged"><ListView.View><GridView><GridViewColumn x:Name="NameColumn" Header="NAME" DisplayMemberBinding="{Binding FriendlyName}"/><GridViewColumn x:Name="CacheKeyColumn" Header="CACHE KEY" DisplayMemberBinding="{Binding Hash}"/><GridViewColumn x:Name="TypeColumn" Header="TYPE" DisplayMemberBinding="{Binding TypeLabel}"/><GridViewColumn x:Name="BytesColumn" Header="BYTES" DisplayMemberBinding="{Binding Size}"/><GridViewColumn x:Name="InlineColumn" Header="INLINE" DisplayMemberBinding="{Binding IsInline}"/></GridView></ListView.View></ListView></Border>
    </Grid>
</UserControl>