<UserControl x:Class="Views.MaintenanceView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel>
        <Border Style="{StaticResource Card}" Margin="0,0,0,16"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Roblox cache location" Style="{StaticResource SectionTitle}"/><TextBlock x:Name="CachePathText" Text="Loading..." Style="{StaticResource MutedText}" Margin="0,6,0,0"/><TextBlock x:Name="CacheSizeText" Text="" Foreground="{StaticResource AccentBrightBrush}" Margin="0,8,0,0"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"><Button Content="Refresh" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="RefreshButton_Click"/><Button Content="Open folder" Style="{StaticResource SecondaryButton}" Click="OpenFolderButton_Click"/></StackPanel></Grid></Border>
        <Border Style="{StaticResource Card}" Margin="0,0,0,16"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="SQL database" Style="{StaticResource SectionTitle}"/><TextBlock Text="If you want to read a different cache, point the scanners at another rbx-storage.db (for example a backup or another account) and reset back to the default with the other button. This is separate from your installation folder." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,6,20,0"/><TextBlock x:Name="DatabasePathText" Text="SQL Database: ..." Foreground="{StaticResource AccentBrightBrush}" Margin="0,8,20,0" TextTrimming="CharacterEllipsis"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"><Button x:Name="ChangeDatabaseButton" Content="Change SQL Database" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="ChangeDatabaseButton_Click"/><Button x:Name="ResetDatabaseButton" Content="Reset SQL Database" Style="{StaticResource SecondaryButton}" IsEnabled="False" Click="ResetDatabaseButton_Click"/></StackPanel></Grid></Border>
        <Border Style="{StaticResource Card}" Margin="0,0,0,16"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Extract everything" Style="{StaticResource SectionTitle}"/><TextBlock Text="Scan the whole cache and dump every recognised asset into one folder, sorted into Audio, Images, Cache Files, Meshes, Thumbnails, Fonts, and Metadata subfolders." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,6,20,0"/></StackPanel><Button x:Name="ExtractAllButton" Grid.Column="1" Content="Extract all" Style="{StaticResource PrimaryButton}" VerticalAlignment="Center" Click="ExtractAllButton_Click"/></Grid></Border>
        <Border Style="{StaticResource Card}" Margin="0,0,0,16"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Clear Roblox asset cache" Style="{StaticResource SectionTitle}"/><TextBlock Text="Deletes rbx-storage.db, external payloads, and Roblox's legacy HTTP cache. You can optionally force-close Roblox and Studio first." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,6,20,0"/></StackPanel><Button Grid.Column="1" Content="Clear cache..." Style="{StaticResource DangerButton}" VerticalAlignment="Center" Click="ClearCacheButton_Click"/></Grid></Border>
        <Border Style="{StaticResource Card}" Margin="0,0,0,16"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="RBX Asset Extractor application data" Style="{StaticResource SectionTitle}"/><TextBlock x:Name="ApplicationDataPathText" Style="{StaticResource MutedText}" Margin="0,6,20,0"/><TextBlock x:Name="ApplicationDataSizeText" Foreground="{StaticResource AccentBrightBrush}" Margin="0,8,0,0"/><TextBlock Text="Stores your saved asset names and diagnostic crash logs. This data remains when the executable is moved or deleted." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,6,20,0"/></StackPanel><Button Grid.Column="1" Content="Clear all application data..." Style="{StaticResource DangerButton}" VerticalAlignment="Center" Click="ClearApplicationDataButton_Click"/></Grid></Border>
        <Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="Cache safety" Style="{StaticResource SectionTitle}"/><TextBlock Text="All scanners open the SQLite database read-only. Exporting writes only to folders you select. Destructive actions live exclusively on this page and require explicit confirmation." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,6,0,0"/></StackPanel></Border>
    </StackPanel></ScrollViewer>
</UserControl>