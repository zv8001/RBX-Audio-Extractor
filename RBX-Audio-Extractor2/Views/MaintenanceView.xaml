<UserControl x:Class="Views.MaintenanceView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel>
        <Border Style="{StaticResource Card}" Margin="0,0,0,16"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Roblox cache location" Style="{StaticResource SectionTitle}"/><TextBlock x:Name="CachePathText" Text="Loading..." Style="{StaticResource MutedText}" Margin="0,6,0,0"/><TextBlock x:Name="CacheSizeText" Text="" Foreground="{StaticResource AccentBrightBrush}" Margin="0,8,0,0"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal"><Button Content="Refresh" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="RefreshButton_Click"/><Button Content="Open folder" Style="{StaticResource SecondaryButton}" Click="OpenFolderButton_Click"/></StackPanel></Grid></Border>
        <Border Style="{StaticResource Card}" Margin="0,0,0,16"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Clear Roblox asset cache" Style="{StaticResource SectionTitle}"/><TextBlock Text="Deletes rbx-storage.db, external payloads, and Roblox's legacy HTTP cache. You can optionally force-close Roblox and Studio first." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,6,20,0"/></StackPanel><Button Grid.Column="1" Content="Clear cache..." Style="{StaticResource DangerButton}" Click="ClearCacheButton_Click"/></Grid></Border>
        <Border Style="{StaticResource Card}" Margin="0,0,0,16"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="RBX Asset Extractor application data" Style="{StaticResource SectionTitle}"/><TextBlock x:Name="ApplicationDataPathText" Style="{StaticResource MutedText}" Margin="0,6,20,0"/><TextBlock x:Name="ApplicationDataSizeText" Foreground="{StaticResource AccentBrightBrush}" Margin="0,8,0,0"/><TextBlock Text="Stores your saved asset names and diagnostic crash logs. This data remains when the executable is moved or deleted." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,6,20,0"/></StackPanel><Button Grid.Column="1" Content="Clear all application data..." Style="{StaticResource DangerButton}" VerticalAlignment="Center" Click="ClearApplicationDataButton_Click"/></Grid></Border>
        <Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="Cache safety" Style="{StaticResource SectionTitle}"/><TextBlock Text="All scanners open the SQLite database read-only. Exporting writes only to folders you select. Destructive actions live exclusively on this page and require explicit confirmation." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,6,0,0"/></StackPanel></Border>
    </StackPanel></ScrollViewer>
</UserControl>