<UserControl x:Class="Views.OverviewView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border CornerRadius="15" Padding="26" Margin="0,0,0,18">
                <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#342757" Offset="0"/><GradientStop Color="#1D2945" Offset="1"/></LinearGradientBrush></Border.Background>
                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel><TextBlock Text="CACHE WORKBENCH" Style="{StaticResource EyebrowText}"/><TextBlock Text="Your Roblox assets, organized." FontSize="28" FontWeight="SemiBold" Margin="0,9,0,5"/><TextBlock Text="Scan the current cache in place, preview what matters, and export only what you choose—without dumping thousands of temporary files." Style="{StaticResource MutedText}" MaxWidth="650" TextWrapping="Wrap"/></StackPanel>
                    <Button Grid.Column="1" Content="Browse audio" Style="{StaticResource PrimaryButton}" Margin="24,0,0,0" Click="BrowseAudio_Click"/>
                </Grid>
            </Border>
            <UniformGrid Columns="4" Margin="0,0,0,18">
                <Border Style="{StaticResource Card}" Margin="0,0,10,0"><StackPanel><TextBlock Text="AUDIO" Style="{StaticResource EyebrowText}"/><TextBlock x:Name="AudioCountText" Text="—" FontSize="27" FontWeight="SemiBold" Margin="0,9,0,2"/><TextBlock Text="cached tracks" Style="{StaticResource MutedText}"/></StackPanel></Border>
                <Border Style="{StaticResource Card}" Margin="4,0,6,0"><StackPanel><TextBlock Text="IMAGES" Style="{StaticResource EyebrowText}"/><TextBlock x:Name="ImageCountText" Text="—" FontSize="27" FontWeight="SemiBold" Margin="0,9,0,2"/><TextBlock Text="previewable files" Style="{StaticResource MutedText}"/></StackPanel></Border>
                <Border Style="{StaticResource Card}" Margin="6,0,4,0"><StackPanel><TextBlock Text="MESHES" Style="{StaticResource EyebrowText}"/><TextBlock x:Name="MeshCountText" Text="—" FontSize="27" FontWeight="SemiBold" Margin="0,9,0,2"/><TextBlock Text="OBJ candidates" Style="{StaticResource MutedText}"/></StackPanel></Border>
                <Border Style="{StaticResource Card}" Margin="10,0,0,0"><StackPanel><TextBlock Text="CACHE FILES" Style="{StaticResource EyebrowText}"/><TextBlock x:Name="CacheCountText" Text="—" FontSize="27" FontWeight="SemiBold" Margin="0,9,0,2"/><TextBlock Text="RBXM and KTX" Style="{StaticResource MutedText}"/></StackPanel></Border>
            </UniformGrid>
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Border Style="{StaticResource Card}" Margin="0,0,9,0"><StackPanel><TextBlock Text="Start with a collection" Style="{StaticResource SectionTitle}"/><TextBlock Text="Each scanner reads the SQLite index directly and loads complete payloads only for preview or export." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,5,0,16"/><WrapPanel><Button Content="Browse audio" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8" Tag="Audio" Click="Navigate_Click"/><Button Content="Browse images" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8" Tag="Images" Click="Navigate_Click"/><Button Content="Browse meshes" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8" Tag="Meshes" Click="Navigate_Click"/></WrapPanel></StackPanel></Border>
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="9,0,0,0"><StackPanel><TextBlock Text="Read-only by default" Style="{StaticResource SectionTitle}"/><TextBlock Text="Scanning and exporting never modify Roblox's database. Cache deletion is isolated under Maintenance and always requires confirmation." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,5,0,16"/><Button Content="Open maintenance" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Tag="Maintenance" Click="Navigate_Click"/></StackPanel></Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>