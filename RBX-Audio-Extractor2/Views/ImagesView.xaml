<UserControl x:Class="Views.ImagesView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <WrapPanel Margin="0,0,0,4">
            <Border Width="300" Height="38" HorizontalAlignment="Left" Margin="0,0,0,8" Style="{StaticResource RoundedTextBoxShell}"><TextBox x:Name="SearchBox" Style="{StaticResource SingleLineTextBox}" TextChanged="SearchBox_TextChanged" ToolTip="Filter by cache key, saved name, or format"/></Border>
            <StackPanel Orientation="Horizontal" Margin="12,0,0,8"><Button x:Name="ScanButton" Content="Scan cache" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Click="ScanButton_Click"/><Button x:Name="RenameButton" Content="Rename" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" IsEnabled="False" Click="RenameButton_Click"/><Button x:Name="ExportButton" Content="Export selected" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" IsEnabled="False" Click="ExportButton_Click"/><Button x:Name="ExportAllButton" Content="Export all" Style="{StaticResource SecondaryButton}" IsEnabled="False" Click="ExportAllButton_Click"/></StackPanel>
        </WrapPanel>
        <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="1.15*"/><ColumnDefinition Width="0.85*"/></Grid.ColumnDefinitions>
            <Border Style="{StaticResource Card}" Padding="8" Margin="0,0,9,0"><ListView x:Name="AssetList" SelectionChanged="AssetList_SelectionChanged" SizeChanged="AssetList_SizeChanged"><ListView.View><GridView><GridViewColumn x:Name="NameColumn" Header="NAME" DisplayMemberBinding="{Binding FriendlyName}"/><GridViewColumn x:Name="CacheKeyColumn" Header="CACHE KEY" DisplayMemberBinding="{Binding Hash}"/><GridViewColumn x:Name="TypeColumn" Header="TYPE" DisplayMemberBinding="{Binding TypeLabel}"/><GridViewColumn x:Name="BytesColumn" Header="BYTES" DisplayMemberBinding="{Binding Size}"/></GridView></ListView.View></ListView></Border>
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="9,0,0,0"><Grid><Image x:Name="PreviewImage" Stretch="Uniform"/><StackPanel x:Name="EmptyPreview" HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="&#xEB9F;" FontFamily="Segoe Fluent Icons" FontSize="38" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"/><TextBlock Text="Select an image to preview" Style="{StaticResource MutedText}" Margin="0,12,0,0"/></StackPanel><Border VerticalAlignment="Bottom" Background="#B0181921" CornerRadius="8" Padding="10" Margin="8"><TextBlock x:Name="PreviewDetails" Text="" Style="{StaticResource MutedText}" TextTrimming="CharacterEllipsis"/></Border></Grid></Border>
        </Grid>
    </Grid>
</UserControl>