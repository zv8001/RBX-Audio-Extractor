<UserControl x:Class="Views.MeshesView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <WrapPanel Margin="0,0,0,4">
            <TextBlock Text="Double-click an exportable mesh for an interactive 3D preview." Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,16,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8"><Button x:Name="ScanButton" Content="Scan cache" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Click="ScanButton_Click"/><Button x:Name="RenameButton" Content="Rename" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" IsEnabled="False" Click="RenameButton_Click"/><Button x:Name="PreviewButton" Content="Preview" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" IsEnabled="False" Click="PreviewButton_Click"/><Button x:Name="ExportButton" Content="Export OBJ" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" IsEnabled="False" Click="ExportButton_Click"/><Button x:Name="ExportAllButton" Content="Export all" Style="{StaticResource SecondaryButton}" IsEnabled="False" Click="ExportAllButton_Click"/></StackPanel>
        </WrapPanel>
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="8"><ListView x:Name="AssetList" SelectionChanged="AssetList_SelectionChanged" MouseDoubleClick="AssetList_MouseDoubleClick" SizeChanged="AssetList_SizeChanged"><ListView.View><GridView><GridViewColumn x:Name="NameColumn" Header="NAME" DisplayMemberBinding="{Binding FriendlyName}"/><GridViewColumn x:Name="CacheKeyColumn" Header="CACHE KEY" DisplayMemberBinding="{Binding Hash}"/><GridViewColumn x:Name="VersionColumn" Header="VERSION" DisplayMemberBinding="{Binding Version}"/><GridViewColumn x:Name="BytesColumn" Header="BYTES" DisplayMemberBinding="{Binding Size}"/><GridViewColumn x:Name="InlineColumn" Header="INLINE" DisplayMemberBinding="{Binding IsInline}"/><GridViewColumn x:Name="ReadyColumn" Header="READY" DisplayMemberBinding="{Binding CanExport}"/></GridView></ListView.View></ListView></Border>
    </Grid>
</UserControl>