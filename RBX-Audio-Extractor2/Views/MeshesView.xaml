<UserControl x:Class="Views.MeshesView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock Text="Double-click an exportable mesh for an interactive 3D preview." Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal"><Button x:Name="ScanButton" Content="Scan cache" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Click="ScanButton_Click"/><Button x:Name="RenameButton" Content="Rename" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" IsEnabled="False" Click="RenameButton_Click"/><Button x:Name="PreviewButton" Content="Preview" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" IsEnabled="False" Click="PreviewButton_Click"/><Button x:Name="ExportButton" Content="Export OBJ" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" IsEnabled="False" Click="ExportButton_Click"/><Button x:Name="ExportAllButton" Content="Export all" Style="{StaticResource SecondaryButton}" IsEnabled="False" Click="ExportAllButton_Click"/></StackPanel>
        </Grid>
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="8"><ListView x:Name="AssetList" SelectionChanged="AssetList_SelectionChanged" MouseDoubleClick="AssetList_MouseDoubleClick"><ListView.View><GridView><GridViewColumn Header="NAME" Width="220" DisplayMemberBinding="{Binding FriendlyName}"/><GridViewColumn Header="CACHE KEY" Width="250" DisplayMemberBinding="{Binding Hash}"/><GridViewColumn Header="VERSION" Width="110" DisplayMemberBinding="{Binding Version}"/><GridViewColumn Header="BYTES" Width="130" DisplayMemberBinding="{Binding Size}"/><GridViewColumn Header="INLINE" Width="90" DisplayMemberBinding="{Binding IsInline}"/><GridViewColumn Header="READY" Width="90" DisplayMemberBinding="{Binding CanExport}"/></GridView></ListView.View></ListView></Border>
    </Grid>
</UserControl>