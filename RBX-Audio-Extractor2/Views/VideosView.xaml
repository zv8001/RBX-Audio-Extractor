<UserControl x:Class="Views.VideosView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <WrapPanel Margin="0,0,0,4">
            <TextBlock Text="Cached HLS playlists are grouped with their VP9/Opus WebM segments." Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,16,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="ScanButton" Content="Scan cache" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Click="ScanButton_Click"/>
                <Button x:Name="RenameButton" Content="Rename" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" IsEnabled="False" Click="RenameButton_Click"/>
                <Button x:Name="PreviewButton" Content="Preview" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" IsEnabled="False" Click="PreviewButton_Click"/>
                <Button x:Name="ExportButton" Content="Export package" ToolTip="Export an HLS playlist with its individual WebM segments" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" IsEnabled="False" Click="ExportButton_Click"/>
                <Button x:Name="ExportSingleFileButton" Content="Export one file" ToolTip="Losslessly combine the cached segments into one WebM file" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" IsEnabled="False" Click="ExportSingleFileButton_Click"/>
                <Button x:Name="ExportAllButton" Content="Export all" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" IsEnabled="False" Click="ExportAllButton_Click"/>
                <CheckBox x:Name="ExportAllSingleFileCheckBox" Content="One file each" ToolTip="When enabled, Export all creates one lossless WebM per video instead of playlist folders" VerticalAlignment="Center"/>
            </StackPanel>
        </WrapPanel>
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="8">
            <ListView x:Name="VideoList" SelectionChanged="VideoList_SelectionChanged" MouseDoubleClick="VideoList_MouseDoubleClick" SizeChanged="VideoList_SizeChanged">
                <ListView.View><GridView>
                    <GridViewColumn x:Name="NameColumn" Header="NAME" DisplayMemberBinding="{Binding FriendlyName}"/>
                    <GridViewColumn x:Name="ResolutionColumn" Header="QUALITY" DisplayMemberBinding="{Binding Resolution}"/>
                    <GridViewColumn x:Name="DurationColumn" Header="DURATION" DisplayMemberBinding="{Binding DurationLabel}"/>
                    <GridViewColumn x:Name="SegmentsColumn" Header="SEGMENTS" DisplayMemberBinding="{Binding SegmentLabel}"/>
                    <GridViewColumn x:Name="BytesColumn" Header="BYTES" DisplayMemberBinding="{Binding Size}"/>
                    <GridViewColumn x:Name="StatusColumn" Header="STATUS" DisplayMemberBinding="{Binding StatusLabel}"/>
                </GridView></ListView.View>
            </ListView>
        </Border>
    </Grid>
</UserControl>