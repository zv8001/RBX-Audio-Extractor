<UserControl x:Class="Views.ExtraAssetsView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <TabControl>
        <TabItem Header="Thumbnails">
            <Grid Margin="0,14,0,0"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,12"><Button x:Name="ScanThumbnailsButton" Content="Scan thumbnails" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Click="ScanThumbnailsButton_Click"/><Button x:Name="ExportThumbnailButton" Content="Export selected" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" IsEnabled="False" Click="ExportThumbnailButton_Click"/><Button x:Name="ExportAllThumbnailsButton" Content="Export all" Style="{StaticResource SecondaryButton}" IsEnabled="False" Click="ExportAllThumbnailsButton_Click"/></StackPanel>
                <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="1.2*"/><ColumnDefinition Width="0.8*"/></Grid.ColumnDefinitions><Border Style="{StaticResource Card}" Padding="8" Margin="0,0,9,0"><ListView x:Name="ThumbnailList" SelectionChanged="ThumbnailList_SelectionChanged"><ListView.View><GridView><GridViewColumn Header="NAME" Width="370" DisplayMemberBinding="{Binding DisplayName}"/><GridViewColumn Header="TYPE" Width="135" DisplayMemberBinding="{Binding TypeLabel}"/><GridViewColumn Header="BYTES" Width="100" DisplayMemberBinding="{Binding Size}"/></GridView></ListView.View></ListView></Border><Border Grid.Column="1" Style="{StaticResource Card}" Margin="9,0,0,0"><Image x:Name="ThumbnailPreview" Stretch="Uniform"/></Border></Grid>
            </Grid>
        </TabItem>
        <TabItem Header="Fonts">
            <Grid Margin="0,14,0,0"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,12"><Button x:Name="ScanFontsButton" Content="Scan fonts" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Click="ScanFontsButton_Click"/><Button x:Name="ExportFontButton" Content="Export selected" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" IsEnabled="False" Click="ExportFontButton_Click"/><Button x:Name="ExportAllFontsButton" Content="Export all" Style="{StaticResource SecondaryButton}" IsEnabled="False" Click="ExportAllFontsButton_Click"/></StackPanel>
                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="8"><ListView x:Name="FontList" SelectionChanged="FontList_SelectionChanged"><ListView.View><GridView><GridViewColumn Header="NAME" Width="470" DisplayMemberBinding="{Binding DisplayName}"/><GridViewColumn Header="TYPE" Width="160" DisplayMemberBinding="{Binding TypeLabel}"/><GridViewColumn Header="BYTES" Width="130" DisplayMemberBinding="{Binding Size}"/></GridView></ListView.View></ListView></Border>
            </Grid>
        </TabItem>
        <TabItem Header="Metadata">
            <Grid Margin="0,14,0,0"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,12"><Button x:Name="ScanMetadataButton" Content="Scan metadata" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Click="ScanMetadataButton_Click"/><Button x:Name="ExportMetadataButton" Content="Export selected" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" IsEnabled="False" Click="ExportMetadataButton_Click"/><Button x:Name="ExportAllMetadataButton" Content="Export all" Style="{StaticResource SecondaryButton}" IsEnabled="False" Click="ExportAllMetadataButton_Click"/></StackPanel>
                <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="0.9*"/><ColumnDefinition Width="1.1*"/></Grid.ColumnDefinitions><Border Style="{StaticResource Card}" Padding="8" Margin="0,0,9,0"><ListView x:Name="MetadataList" SelectionChanged="MetadataList_SelectionChanged"><ListView.View><GridView><GridViewColumn Header="NAME" Width="330" DisplayMemberBinding="{Binding DisplayName}"/><GridViewColumn Header="TYPE" Width="110" DisplayMemberBinding="{Binding TypeLabel}"/></GridView></ListView.View></ListView></Border><Border Grid.Column="1" Style="{StaticResource Card}" Margin="9,0,0,0"><TextBox x:Name="MetadataPreview" IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True" FontFamily="Cascadia Mono, Consolas" Foreground="{StaticResource TextBrush}" Background="Transparent" BorderThickness="0" Padding="12" TextOptions.TextFormattingMode="Display">
                            <TextBox.Template>
                                <ControlTemplate TargetType="{x:Type TextBox}">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>
                                    </Border>
                                </ControlTemplate>
                            </TextBox.Template>
                        </TextBox></Border></Grid>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>