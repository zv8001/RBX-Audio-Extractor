<UserControl x:Class="Views.AudioView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="110"/></Grid.RowDefinitions>
        <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox" Width="300" HorizontalAlignment="Left" TextChanged="SearchBox_TextChanged" ToolTip="Filter by cache hash or format"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal"><Button x:Name="ScanButton" Content="Scan cache" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Click="ScanButton_Click"/><Button x:Name="ExportButton" Content="Export selected" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" IsEnabled="False" Click="ExportButton_Click"/><Button x:Name="ExportAllButton" Content="Export all" Style="{StaticResource SecondaryButton}" IsEnabled="False" Click="ExportAllButton_Click"/></StackPanel>
        </Grid>
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="8">
            <ListView x:Name="AssetList" SelectionChanged="AssetList_SelectionChanged" MouseDoubleClick="AssetList_MouseDoubleClick">
                <ListView.View><GridView><GridViewColumn Header="CACHE KEY" Width="380" DisplayMemberBinding="{Binding Hash}"/><GridViewColumn Header="FORMAT" Width="125" DisplayMemberBinding="{Binding TypeLabel}"/><GridViewColumn Header="DURATION" Width="100" DisplayMemberBinding="{Binding DurationText}"/><GridViewColumn Header="BYTES" Width="130" DisplayMemberBinding="{Binding Size}"/><GridViewColumn Header="INLINE" Width="90" DisplayMemberBinding="{Binding IsInline}"/></GridView></ListView.View>
            </ListView>
        </Border>
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,12,0,0" Padding="16">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal"><Button x:Name="PlayPauseButton" Content="Play" Style="{StaticResource PrimaryButton}" Width="76" Click="PlayPauseButton_Click"/><Button Content="Stop" Style="{StaticResource SecondaryButton}" Width="70" Margin="8,0,0,0" Click="StopButton_Click"/></StackPanel>
                <StackPanel Grid.Column="1" Margin="18,0"><TextBlock x:Name="NowPlayingText" Text="Select a track to preview" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/><Grid Margin="0,9,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="96"/></Grid.ColumnDefinitions><Slider x:Name="PositionSlider" Minimum="0" Maximum="1" PreviewMouseLeftButtonDown="PositionSlider_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="PositionSlider_PreviewMouseLeftButtonUp"/><TextBlock x:Name="TimeText" Grid.Column="1" Text="00:00 / 00:00" Style="{StaticResource MutedText}" HorizontalAlignment="Right"/></Grid></StackPanel>
                <StackPanel Grid.Column="2"><TextBlock Text="VOLUME" Style="{StaticResource EyebrowText}"/><Slider x:Name="VolumeSlider" Minimum="0" Maximum="1" Value="0.85" Margin="0,8,0,0" ValueChanged="VolumeSlider_ValueChanged"/></StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>